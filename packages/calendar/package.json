{
  "name": "@vuepkg/calendar",
  "private": false,
  "version": "0.6.2",
  "description": "Vue 3 schedule calendar — Month / Week / Day / List views, zero extra dependencies",
  "keywords": [
    "vue",
    "vue3",
    "vue3-calendar",
    "calendar-component",
    "calendar",
    "schedule",
    "scheduler",
    "typescript",
    "drag-drop",
    "event-calendar",
    "weekly-calendar",
    "monthly-calendar",
    "recurring-events"
  ],
  "homepage": "https://vuepkg.github.io/calendar/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepkg/calendar.git"
  },
  "bugs": {
    "url": "https://github.com/vuepkg/calendar/issues"
  },
  "author": "vuepkg",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/components/calendar/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/components/calendar/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/components/calendar/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless.d.ts",
        "default": "./dist/headless.js"
      },
      "require": {
        "types": "./dist/headless.d.ts",
        "default": "./dist/headless.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vue-tsc --noEmit -p tsconfig.app.json && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:api:check": "node scripts/generate-api-docs.mjs && git diff --exit-code -- ../../apps/docs/api/_generated/schedule-calendar-api.md",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . && eslint . --fix",
    "format:check": "prettier --check . && eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test e2e/calendar.spec.ts e2e/calendar-responsive.spec.ts e2e/calendar-host-integration.spec.ts e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:update-snapshots:linux": "bash scripts/update-visual-snapshots-linux.sh",
    "test:e2e:responsive": "playwright test e2e/calendar-responsive.spec.ts",
    "test:e2e:host": "playwright test e2e/calendar-host-integration.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "release": "pnpm run build:lib && npm publish --access public",
    "size": "size-limit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "size-limit": [
    {
      "name": "index.js (ESM)",
      "path": [
        "dist/index.js",
        "dist/headless-*.js"
      ],
      "limit": "20 kB"
    },
    {
      "name": "index.cjs (CJS)",
      "path": [
        "dist/index.cjs",
        "dist/headless-*.cjs"
      ],
      "limit": "19 kB"
    },
    {
      "name": "headless.js (ESM)",
      "path": [
        "dist/headless.js",
        "dist/headless-*.js"
      ],
      "limit": "9 kB"
    },
    {
      "name": "style.css",
      "path": "dist/style.css",
      "limit": "8 kB"
    }
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vuepkg/core": "workspace:*",
    "@vuepkg/ui": "workspace:*",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.34",
    "vue-component-meta": "^3.3.6",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
