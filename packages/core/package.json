{
  "name": "@vuepkg/core",
  "private": false,
  "version": "0.1.1",
  "description": "Core utilities, composables, and types for @vuepkg",
  "keywords": [
    "vue",
    "vue3",
    "vuepkg"
  ],
  "homepage": "https://github.com/vuepkg/calendar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepkg/calendar.git"
  },
  "author": "vuepkg",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./utils/date": {
      "import": {
        "types": "./dist/utils/date.d.ts",
        "default": "./dist/utils/date.esm.js"
      },
      "require": {
        "types": "./dist/utils/date.d.ts",
        "default": "./dist/utils/date.cjs.js"
      }
    },
    "./utils/holiday": {
      "import": {
        "types": "./dist/utils/holiday.d.ts",
        "default": "./dist/utils/holiday.esm.js"
      },
      "require": {
        "types": "./dist/utils/holiday.d.ts",
        "default": "./dist/utils/holiday.cjs.js"
      }
    },
    "./composables/useControllableState": {
      "import": {
        "types": "./dist/composables/useControllableState.d.ts",
        "default": "./dist/composables/useControllableState.esm.js"
      },
      "require": {
        "types": "./dist/composables/useControllableState.d.ts",
        "default": "./dist/composables/useControllableState.cjs.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:lib": "vue-tsc --noEmit -p tsconfig.app.json && vite build --config vite.lib.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "size": "size-limit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "size-limit": [
    {
      "name": "index.esm.js",
      "path": "dist/index.esm.js",
      "limit": "3 kB"
    },
    {
      "name": "index.cjs.js",
      "path": "dist/index.cjs.js",
      "limit": "3 kB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "vue": "^3.5.34",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
