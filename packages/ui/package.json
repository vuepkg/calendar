{
  "name": "@vuepkg/ui",
  "private": true,
  "version": "0.2.2",
  "description": "Headless-friendly Vue 3 UI primitives for @vuepkg",
  "keywords": [
    "vue",
    "vue3",
    "vuepkg",
    "ui",
    "components"
  ],
  "homepage": "https://github.com/vuepkg/calendar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepkg/calendar.git"
  },
  "author": "vuepkg",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./DataTable": {
      "import": {
        "types": "./dist/DataTable.d.ts",
        "default": "./dist/DataTable.esm.js"
      },
      "require": {
        "types": "./dist/DataTable.d.ts",
        "default": "./dist/DataTable.cjs.js"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "vue-tsc --noEmit -p tsconfig.app.json && vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:e2e": "playwright test",
    "size": "size-limit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "size-limit": [
    {
      "name": "index.esm.js",
      "path": "dist/index.esm.js",
      "limit": "5 kB"
    },
    {
      "name": "index.cjs.js",
      "path": "dist/index.cjs.js",
      "limit": "5 kB"
    },
    {
      "name": "style.css",
      "path": "dist/style.css",
      "limit": "2 kB"
    }
  ],
  "dependencies": {
    "@vuepkg/core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "vue": "^3.5.34",
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
