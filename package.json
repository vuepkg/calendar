{
  "name": "@vuepkg/root",
  "private": true,
  "version": "0.0.0",
  "description": "vuepkg monorepo — Vue 3 UI framework",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepkg/calendar.git"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@vuepkg/calendar",
    "build": "turbo run build:lib",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:ci": "pnpm --filter @vuepkg/calendar run test:e2e:ci",
    "test:e2e:visual": "pnpm --filter @vuepkg/calendar run test:e2e:visual",
    "verify:push": "pnpm turbo run lint typecheck test",
    "prepare": "husky",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
